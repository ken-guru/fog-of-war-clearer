# fog-of-war-clearer configuration
# Copy this file to .env and fill in your values
# .env is ignored by git and should never be committed

# GitHub Personal Access Token (required for git clone access)
# Must have 'repo' (read) scope
FOG_PAT=ghp_your_token_here

# Repository to analyze (required)
# Format: owner/repo-name
FOG_REPO=owner/repo-name

# Checks to run (optional, comma-separated)
# Default: test-coverage
FOG_CHECKS=test-coverage

# --- LLM Planner (optional) ---
# When FOG_LLM_MODEL is set, a containerised Ollama instance is used to
# dynamically determine the right Docker image and test commands for each
# repository.  If unset (or the LLM fails), a static fallback is used.

# Ollama model tag (default: qwen2.5:1.5b, ~900 MB)
# FOG_LLM_MODEL=qwen2.5:1.5b

# Ollama Docker image (default: ollama/ollama:latest)
# FOG_LLM_OLLAMA_IMAGE=ollama/ollama:latest
