# fog-of-war-clearer configuration
# Copy this file to .env and fill in your values
# .env is ignored by git and should never be committed

# GitHub Personal Access Token (required for git clone access)
# Must have 'repo' (read) scope
FOG_PAT=ghp_your_token_here

# Repository to analyze (required)
# Format: owner/repo-name
FOG_REPO=owner/repo-name

# Checks to run (optional, comma-separated)
# Default: test-coverage
FOG_CHECKS=test-coverage
